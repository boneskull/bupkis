{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "exclude": ["duplicates"],
  "tags": ["-knipignore"],
  "workspaces": {
    ".": {
      "entry": [".config/eslint-rules/*.js"],
      "ignore": [".wallaby.js", ".claude/**", "**/examples/**"],
      "ignoreDependencies": [
        "@types/wallabyjs",
        "markdownlint-cli2-formatter-pretty"
      ]
    },
    "packages/bupkis": {
      "entry": [
        "src/assertion/index.ts",
        "src/index.ts",
        "src/types.ts",
        "src/util.ts",
        "src/schema.ts",
        "src/guards.ts",
        "src/diff.ts",
        "src/snapshot/index.ts",
        "test-data/index.ts",
        "bench/**/*.bench.ts",
        "scripts/*.ts",
        "test/**/*.test.ts"
      ],
      "ignore": ["test-d/**/*.test-d.ts"]
    },
    "packages/sinon": {
      "entry": ["src/index.ts", "test/**/*.test.ts"]
    }
  }
}
