{
  "name": "bupkis-monorepo",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": "^22.22.2 || ^24.15.0 || >=26.0.0"
  },
  "scripts": {
    "bench": "npm run bench --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "commitlint": "commitlint",
    "docs:build": "typedoc --options .config/typedoc.js --cleanOutputDir --treatWarningsAsErrors",
    "docs:build:watch": "run-s -s \"docs:build -- --watch\"",
    "docs:dev": "run-p -sl docs:build:watch docs:serve",
    "docs:serve": "npx -y serve docs",
    "fix": "run-s -sl fix:*",
    "fix:eslint": "eslint --fix .",
    "fix:markdown": "markdownlint-cli2 --fix \"**/*.md\"",
    "fix:pkg": "npm pkg fix",
    "fix:prettier": "prettier --write .",
    "lint": "run-p -sl --aggregate-output lint:*",
    "lint-staged": "lint-staged",
    "lint:engines": "installed-check --engine-check",
    "lint:eslint": "eslint .",
    "lint:knip": "knip",
    "lint:markdown": "markdownlint-cli2 \"**/*.md\"",
    "lint:prettier": "prettier --check .",
    "lint:spelling": "cspell .",
    "lint:types": "tsc --noEmit",
    "prepare": "husky; npm run build",
    "test": "npm run test --workspaces",
    "test:ci": "npm run test:ci --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "test:fuzz": "npm run test:fuzz --workspace=bupkis",
    "test:property": "npm run test:property --workspaces --if-present",
    "test:snapshots": "npm run test:snapshots --workspaces --if-present",
    "test:types": "npm run test:types --workspaces --if-present"
  },
  "devDependencies": {
    "@bupkis/property-testing": "^0.1.0",
    "@commitlint/cli": "21.1.0",
    "@commitlint/config-conventional": "21.1.0",
    "@eslint/js": "10.0.1",
    "@stylistic/eslint-plugin": "5.10.0",
    "@tsconfig/node22": "22.0.5",
    "@types/node": "22.20.0",
    "@types/slug": "5.0.9",
    "@types/wallabyjs": "0.0.15",
    "@typescript-eslint/typescript-estree": "8.62.0",
    "@typescript-eslint/utils": "8.62.0",
    "arktype": "2.2.1",
    "bupkis": "^0.16.0",
    "c8": "11.0.0",
    "cspell": "10.0.1",
    "escape-string-regexp": "5.0.0",
    "eslint": "10.6.0",
    "eslint-plugin-jsonc": "3.2.0",
    "eslint-plugin-n": "18.2.1",
    "eslint-plugin-perfectionist": "5.9.1",
    "eslint-plugin-prefer-arrow-functions": "3.10.1",
    "eslint-plugin-zod": "4.7.0",
    "fast-check": "4.5.3",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "installed-check": "10.0.1",
    "knip": "6.25.0",
    "lint-staged": "17.0.8",
    "markdownlint-cli2": "0.23.0",
    "markdownlint-cli2-formatter-pretty": "0.0.10",
    "modestbench": "0.9.3",
    "node-test-github-reporter": "1.3.2",
    "npm-run-all2": "9.0.2",
    "prettier": "3.9.1",
    "prettier-plugin-jsdoc": "1.8.1",
    "prettier-plugin-pkg": "0.22.1",
    "tsd": "0.33.0",
    "tsx": "4.22.4",
    "typedoc": "0.28.19",
    "typedoc-plugin-dt-links": "2.0.61",
    "typedoc-plugin-extras": "4.0.1",
    "typedoc-plugin-llms-txt": "0.1.2",
    "typedoc-plugin-mdn-links": "5.1.1",
    "typedoc-plugin-redirect": "1.3.0",
    "typedoc-plugin-zod": "1.4.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "valibot": "1.4.2",
    "zshy": "0.7.3"
  },
  "overrides": {
    "conventional-commits-parser": "7.0.1"
  },
  "knip": {
    "ignoreDependencies": [
      "node-test-github-reporter"
    ]
  },
  "lint-staged": {
    "*.md": [
      "markdownlint-cli2 --fix",
      "prettier --write",
      "cspell lint --no-must-find-files"
    ],
    "**/!(package-lock).json": [
      "eslint --fix",
      "prettier --write",
      "cspell lint --no-must-find-files"
    ],
    "*.{ts,js,cjs,yaml,yml,json5}": [
      "eslint --fix",
      "prettier --write",
      "cspell lint --no-must-find-files"
    ]
  },
  "prettier": {
    "jsdocCommentLineStrategy": "keep",
    "jsdocPreferCodeFences": true,
    "plugins": [
      "prettier-plugin-jsdoc",
      "prettier-plugin-pkg"
    ],
    "singleQuote": true,
    "tsdoc": true
  }
}
